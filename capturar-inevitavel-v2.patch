+            body = resp.read(MAX_ASSET_BYTES + 1)
+            if len(body) > MAX_ASSET_BYTES:
+                return None, content_type
+            return body, content_type
+    except (urllib.error.URLError, TimeoutError, ValueError):
+        return None, ""
