+def _discover_links(page_url: str, html: str, root_url: str) -> list[str]:
+    root_scheme, root_netloc = _origin(root_url)
+    soup = BeautifulSoup(html, "html.parser")
+    found: list[str] = []
+    seen: set[str] = set()
