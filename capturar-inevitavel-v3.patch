+  function setProgress(pct) {
+    document.getElementById('progressBar').style.width = pct + '%';
+    document.getElementById('progressPct').textContent = Math.round(pct) + '%';
+  }
+
+  function showSection(id) {
+    const el = document.getElementById(id);
+    el.style.display = 'block';
+    requestAnimationFrame(() => el.classList.add('shown'));
+  }
+
+  function showError(msg) {
+    const toast = document.getElementById('errorToast');
+    toast.textContent = '✕ ' + msg;
+    toast.classList.add('show');
+    setTimeout(() => toast.classList.remove('show'), 4000);
+  }
+
+  function resetBtn() {
+    const btn = document.getElementById('btnDownload');
+    const label = document.getElementById('btnLabel');
+    const icon = document.getElementById('btnIcon');
+    btn.disabled = false;
+    label.textContent = 'Capturar';
+    icon.innerHTML = '<path d="M7 1v8M4 7l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>';
+  }
+
+  function getUrl() {
+    let v = document.getElementById('urlInput').value.trim();
+    if (!v) return null;
+    if (!/^https?:\/\//i.test(v)) v = 'https://' + v;
+    return v;
+  }
+
+  function formatTime(ms) {
+    if (ms < 1000) return ms + 'ms';
+    return (ms / 1000).toFixed(1) + 's';
+  }
+
+  function formatBytes(bytes) {
+    if (!bytes) return '—';
+    if (bytes < 1024) return bytes + ' B';
+    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
+    return (bytes / 1024 / 1024).toFixed(2) + ' MB';
+  }
+
+  async function startDownload() {
+    if (isRunning) return;
+    const url = getUrl();
+    if (!url) { showError('Cole uma URL válida primeiro.'); return; }
+
+    try { new URL(url); } catch { showError('URL inválida.'); return; }
+
+    isRunning = true;
+    startTime = Date.now();
+
+    // Reset UI
+    document.getElementById('logBox').innerHTML = '';
+    document.getElementById('resultSection').style.display = 'none';
+    setProgress(0);
+
+    // Show progress
+    const ps = document.getElementById('progressSection');
+    ps.style.display = 'block';
+    ps.classList.remove('shown');
+    requestAnimationFrame(() => ps.classList.add('shown'));
+
+    // Update btn
+    const btn = document.getElementById('btnDownload');
+    const label = document.getElementById('btnLabel');
+    const icon = document.getElementById('btnIcon');
+    btn.disabled = true;
+    label.textContent = 'Capturando';
+    icon.innerHTML = '<div class="spin"></div>';
+
+    const hostname = new URL(url).hostname.replace('www.', '');
+
+    // Conecta ao backend real via SSE
+    const params = new URLSearchParams({
+      url,
+      js: document.getElementById('optJS').checked,
+      lazy: document.getElementById('optLazy').checked,
+      clean: document.getElementById('optClean').checked,
+    });
+    eventSource = new EventSource(`/download?${params}`);
+
+    eventSource.onmessage = e => {
+      const data = JSON.parse(e.data);
+      if (data.type === 'log') { log(data.msg, data.level || ''); }
+      if (data.progress !== undefined) { setProgress(data.progress); }
+      if (data.type === 'done') {
+        finishDownload(data, hostname);
+        eventSource.close();
+      }
+      if (data.type === 'error') {
+        showError(data.msg);
+        resetBtn();
+        isRunning = false;
+        eventSource.close();
+      }
+    };
+    eventSource.onerror = () => {
+      if (!isRunning) return;
+      showError('Falha na conexão com o servidor.');
+      resetBtn();
+      isRunning = false;
+      eventSource && eventSource.close();
+    };
+  }
+
+  function finishDownload(data, hostname) {
+    const elapsed = data.elapsed || (Date.now() - startTime);
+    document.getElementById('resultFilename').textContent = data.filename || `${hostname}.zip`;
+    document.getElementById('resultSize').textContent = formatBytes(data.size);
+    document.getElementById('resultFiles').textContent = data.files || '—';
+    document.getElementById('resultTime').textContent = formatTime(elapsed);
+
+    if (data.downloadUrl) {
+      document.getElementById('resultLink').href = data.downloadUrl;
+    }
+
+    const dsLink = document.getElementById('designSystemLink');
+    if (data.designSystemUrl) {
+      dsLink.href = data.designSystemUrl;
+      dsLink.style.display = 'inline-flex';
+    } else {
+      dsLink.href = '#';
+      dsLink.style.display = 'none';
+    }
+    const detailBits = [];
+    if (data.pages) detailBits.push(`${data.pages} páginas`);
+    if (data.unresolved !== undefined && data.unresolved !== null) detailBits.push(`${data.unresolved} remotos pendentes`);
+    const helper = document.querySelector('.result-info div[style]');
+    if (helper && detailBits.length) {
+      helper.textContent = `inclui múltiplas páginas locais + assets/ + capture-manifest.json · ${detailBits.join(' · ')}${data.designSystemUrl ? ' · design-system.html' : ''}`;
+    }
+
+    document.getElementById('resultSection').style.display = 'block';
+    resetBtn();
+    isRunning = false;
+  }
+
+  // Allow Enter key
+  document.getElementById('urlInput').addEventListener('keydown', e => {
+    if (e.key === 'Enter') startDownload();
+  });
+</script>
+</body>
+</html>
