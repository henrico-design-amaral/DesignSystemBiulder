# Core runtime
PORT=8080
DOWNLOAD_RETENTION_SECONDS=600
MAX_CONCURRENT_JOBS=2
MAX_URL_LENGTH=2048

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=5

# Capture limits
MAX_ASSET_BYTES=26214400
MAX_CAPTURED_RESOURCES=900
MAX_CRAWL_PAGES=14
MAX_CRAWL_DEPTH=2
MAX_CSS_IMPORT_DEPTH=4

# Optional access control
APP_API_TOKEN=
ALLOWED_DOMAIN_SUFFIXES=
DENIED_DOMAIN_SUFFIXES=localhost,local,internal,test,example,invalid

# Optional design-system API
DESIGN_SYSTEM_MODE=local
ANTHROPIC_API_KEY=

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=240
GUNICORN_GRACEFUL_TIMEOUT=30
LOG_LEVEL=info
